---
import Layout from '../../layouts/Layout.astro';
import GitCommitPanel from '../../components/GitCommitPanel.tsx';
import { getProjectsDir, getProjectSessions, listSessionFiles, deriveProjectName } from '../../lib/projects.ts';
import { getSessionMetadata } from '../../lib/parser.ts';
import { getGitBranch } from '../../lib/git.ts';
import { join } from 'node:path';

const { id } = Astro.params;
if (!id) return Astro.redirect('/');

const projectDir = join(getProjectsDir(), id);
const sessions   = await getProjectSessions(id);

let cwd = '';
const sessionFiles = listSessionFiles(projectDir);
if (sessionFiles.length > 0) {
  try { const meta = await getSessionMetadata(sessionFiles[0]); cwd = meta.cwd; } catch {}
}

const name   = deriveProjectName(cwd, id);
const branch = cwd ? getGitBranch(cwd) : null;

// ── Group sessions by day for timeline ───────────────────────────────────────
const grouped = new Map<string, typeof sessions>();
for (const s of sessions) {
  const key = new Date(s.timestamp).toLocaleDateString('en-US', {
    weekday: 'short', year: 'numeric', month: 'short', day: 'numeric',
  });
  if (!grouped.has(key)) grouped.set(key, []);
  grouped.get(key)!.push(s);
}

function formatTime(d: Date | string) {
  return new Date(d).toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit' });
}
---

<Layout title={`${name} — Claude Conversations`} back={{ href: '/', label: 'Projects' }}>
  <div class="flex gap-6">
    <!-- Timeline -->
    <div class="flex-1 min-w-0">
      <div class="mb-6">
        <div class="flex items-center gap-3 mb-1">
          <svg class="h-5 w-5 text-gray-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
              d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z" />
          </svg>
          <h1 class="text-xl font-bold text-gray-100">{name}</h1>
        </div>
        <p class="text-sm text-gray-500">{cwd || projectDir}</p>
        <p class="text-xs text-gray-600 mt-1">{sessions.length} {sessions.length === 1 ? 'session' : 'sessions'}</p>
      </div>

      {sessions.length === 0 ? (
        <p class="text-gray-500 text-sm">No sessions found.</p>
      ) : (
        <div class="relative">
          <!-- Vertical rail -->
          <div class="absolute left-[7px] top-4 bottom-0 w-px bg-gray-800" />

          <div class="space-y-6 pl-0">
            {[...grouped.entries()].map(([dayLabel, daySessions]) => (
              <div>
                <!-- Day marker -->
                <div class="flex items-center gap-3 mb-3">
                  <div class="relative z-10 w-4 h-4 rounded-full bg-gray-700 border-2 border-gray-600 flex-shrink-0" />
                  <span class="text-xs font-semibold text-gray-500 uppercase tracking-wider">{dayLabel}</span>
                </div>

                <!-- Sessions for this day -->
                <div class="ml-10 space-y-2">
                  {daySessions.map(session => (
                    <a
                      href={`/sessions/${session.id}`}
                      class="group flex items-start gap-3 rounded-lg border border-gray-800 bg-[#161b22] px-4 py-3 hover:border-gray-600 hover:bg-[#1c2128] transition-colors"
                    >
                      <span class="text-xs text-gray-600 font-mono flex-shrink-0 mt-0.5 w-12">
                        {formatTime(session.timestamp)}
                      </span>

                      <div class="flex-1 min-w-0">
                        <div class="flex items-center gap-2 flex-wrap">
                          <span class="font-medium text-sm text-blue-400 group-hover:underline truncate">
                            {session.slug || session.id.slice(0, 8)}
                          </span>
                          {session.gitBranch && (
                            <span class="flex items-center gap-0.5 text-[10px] text-gray-500 bg-gray-800 rounded px-1.5 py-0.5">
                              <svg class="h-2.5 w-2.5" fill="currentColor" viewBox="0 0 16 16">
                                <path d="M11.75 2.5a.75.75 0 100 1.5.75.75 0 000-1.5zm-2.25.75a2.25 2.25 0 113 2.122V6A2.5 2.5 0 019 8.5H7a1 1 0 00-1 1v1.128a2.251 2.251 0 11-1.5 0V5.372a2.25 2.25 0 111.5 0v1.836A2.493 2.493 0 017 7h2a1 1 0 001-1v-.628A2.25 2.25 0 019.5 3.25zM4.25 12a.75.75 0 100 1.5.75.75 0 000-1.5zM3.5 3.25a.75.75 0 111.5 0 .75.75 0 01-1.5 0z" />
                              </svg>
                              {session.gitBranch}
                            </span>
                          )}
                        </div>
                        {session.firstMessage && (
                          <p class="mt-0.5 text-xs text-gray-500 truncate">{session.firstMessage}</p>
                        )}
                      </div>

                      <div class="flex-shrink-0 flex items-center gap-3 text-xs text-gray-600">
                        <span>{session.messageCount} msgs</span>
                        <a
                          href={`/compare?a=${session.id}`}
                          class="hidden group-hover:inline text-gray-700 hover:text-blue-400 transition-colors"
                          title="Compare this session"
                          onclick="event.stopPropagation()"
                        >
                          ⇄
                        </a>
                      </div>
                    </a>
                  ))}
                </div>
              </div>
            ))}
          </div>
        </div>
      )}
    </div>

    <!-- Git commit panel -->
    <aside class="hidden lg:block w-80 flex-shrink-0">
      <GitCommitPanel cwd={cwd || projectDir} branch={branch} client:load />
    </aside>
  </div>
</Layout>
