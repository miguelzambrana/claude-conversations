---
import Layout from '../layouts/Layout.astro';
import { getAllSessionStats, aggregateStats, formatCost } from '../lib/analytics.ts';

const sessions = await getAllSessionStats();
const agg      = aggregateStats(sessions);

const maxProject = agg.projectCosts[0]?.cost ?? 1;
const maxTool    = agg.toolUsage[0]?.[1] ?? 1;
const maxMonthly = Math.max(...agg.monthlyCosts.map(m => m.cost), 0.01);

// ── Activity heatmap (last 52 weeks) ──────────────────────────────────────────
const WEEKS = 52;
const heatmapEnd = new Date();
const heatmapStart = new Date(heatmapEnd);
heatmapStart.setDate(heatmapEnd.getDate() - WEEKS * 7 + 1);
// Align start to Monday
const startDow = heatmapStart.getDay();
heatmapStart.setDate(heatmapStart.getDate() - (startDow === 0 ? 6 : startDow - 1));

const heatmapCells: Array<{ date: string; count: number; future: boolean }> = [];
const heatmapMonths: Array<{ label: string; col: number }> = [];
const cur = new Date(heatmapStart);
let lastMonth = -1;
for (let col = 0; col < WEEKS; col++) {
  for (let row = 0; row < 7; row++) {
    const dateStr = cur.toISOString().slice(0, 10);
    if (cur.getDate() === 1 || (col === 0 && row === 0)) {
      const month = cur.getMonth();
      if (month !== lastMonth) {
        heatmapMonths.push({ label: cur.toLocaleString('en-US', { month: 'short' }), col });
        lastMonth = month;
      }
    }
    heatmapCells.push({ date: dateStr, count: agg.sessionsByDay.get(dateStr) ?? 0, future: cur > heatmapEnd });
    cur.setDate(cur.getDate() + 1);
  }
}

function heatColor(count: number): string {
  if (count === 0) return '#161b22';
  if (count === 1) return '#0e4429';
  if (count === 2) return '#006d32';
  if (count <= 4)  return '#26a641';
  return '#39d353';
}

const modelTotal = agg.modelCounts.sonnet + agg.modelCounts.opus + agg.modelCounts.haiku;
function pct(n: number) { return modelTotal ? `${((n / modelTotal) * 100).toFixed(1)}%` : '0%'; }
---

<Layout title="Analytics — Claude Conversations">
  <div class="mb-8">
    <h1 class="text-2xl font-bold text-gray-100">Analytics</h1>
    <p class="mt-1 text-sm text-gray-500">Usage and cost across all {agg.totalSessions} sessions</p>
  </div>

  <!-- ── Summary cards ── -->
  <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 mb-8">
    {[
      { label: 'Total cost',     value: formatCost(agg.totalCost),     sub: 'all time',       color: 'text-emerald-400' },
      { label: 'This month',     value: formatCost(agg.thisMonthCost), sub: new Date().toLocaleString('en-US',{month:'long'}), color: 'text-emerald-400' },
      { label: 'Sessions',       value: String(agg.totalSessions),     sub: 'total',          color: 'text-blue-400' },
      { label: 'Messages',       value: agg.totalMessages.toLocaleString(), sub: 'exchanged', color: 'text-purple-400' },
    ].map(card => (
      <div class="rounded-lg border border-gray-700 bg-[#161b22] p-4">
        <p class="text-xs text-gray-500 uppercase tracking-wider">{card.label}</p>
        <p class={`mt-1 text-2xl font-bold font-mono ${card.color}`}>{card.value}</p>
        <p class="text-xs text-gray-600 mt-0.5">{card.sub}</p>
      </div>
    ))}
  </div>

  <div class="grid lg:grid-cols-2 gap-8">

    <!-- ── Monthly cost bar chart ── -->
    <div class="rounded-lg border border-gray-700 bg-[#161b22] p-5">
      <h2 class="text-sm font-semibold text-gray-300 mb-4">Monthly Cost</h2>
      <div class="flex items-end gap-1 h-32">
        {agg.monthlyCosts.map(({ label, cost }) => {
          const h = Math.round((cost / maxMonthly) * 100);
          return (
            <div class="flex-1 flex flex-col items-center gap-1" title={`${label}: ${formatCost(cost)}`}>
              <div
                class="w-full rounded-t bg-emerald-700 hover:bg-emerald-500 transition-colors"
                style={`height: ${Math.max(h, cost > 0 ? 4 : 0)}%`}
              />
              <span class="text-[9px] text-gray-600 rotate-0 whitespace-nowrap">{label}</span>
            </div>
          );
        })}
      </div>
    </div>

    <!-- ── Model distribution ── -->
    <div class="rounded-lg border border-gray-700 bg-[#161b22] p-5">
      <h2 class="text-sm font-semibold text-gray-300 mb-4">Model Distribution</h2>
      {modelTotal > 0 ? (
        <div>
          <div class="flex rounded-full overflow-hidden h-6 mb-4" title="Model usage split">
            {agg.modelCounts.sonnet > 0 && <div class="bg-blue-600" style={`width: ${pct(agg.modelCounts.sonnet)}`} />}
            {agg.modelCounts.opus   > 0 && <div class="bg-rose-600" style={`width: ${pct(agg.modelCounts.opus)}`} />}
            {agg.modelCounts.haiku  > 0 && <div class="bg-teal-600" style={`width: ${pct(agg.modelCounts.haiku)}`} />}
          </div>
          <div class="space-y-2">
            {([['sonnet','bg-blue-600','text-blue-400'],['opus','bg-rose-600','text-rose-400'],['haiku','bg-teal-600','text-teal-400']] as const).map(([key, bg, text]) => (
              agg.modelCounts[key] > 0 && (
                <div class="flex items-center gap-2 text-xs">
                  <span class={`w-3 h-3 rounded-sm flex-shrink-0 ${bg}`} />
                  <span class={`font-medium ${text} capitalize w-12`}>{key}</span>
                  <div class="flex-1 h-1.5 rounded-full bg-gray-800">
                    <div class={`h-full rounded-full ${bg}`} style={`width: ${pct(agg.modelCounts[key])}`} />
                  </div>
                  <span class="text-gray-400 w-10 text-right">{pct(agg.modelCounts[key])}</span>
                  <span class="text-gray-600">{agg.modelCounts[key]}s</span>
                </div>
              )
            ))}
          </div>
        </div>
      ) : (
        <p class="text-gray-600 text-sm">No model data yet</p>
      )}
    </div>

    <!-- ── Cost by project ── -->
    <div class="rounded-lg border border-gray-700 bg-[#161b22] p-5">
      <h2 class="text-sm font-semibold text-gray-300 mb-4">Cost by Project</h2>
      {agg.projectCosts.length > 0 ? (
        <div class="space-y-2">
          {agg.projectCosts.map(({ id, name, cost, sessions: sc }) => (
            <div class="flex items-center gap-2">
              <a href={`/projects/${id}`} class="text-xs text-gray-400 hover:text-blue-400 transition-colors w-28 truncate flex-shrink-0" title={name}>
                {name}
              </a>
              <div class="flex-1 h-4 rounded bg-gray-800 overflow-hidden">
                <div
                  class="h-full rounded bg-emerald-700 hover:bg-emerald-500 transition-colors"
                  style={`width: ${(cost / maxProject) * 100}%`}
                  title={formatCost(cost)}
                />
              </div>
              <span class="text-xs text-emerald-500 font-mono w-16 text-right">{formatCost(cost)}</span>
              <span class="text-xs text-gray-600 w-10 text-right">{sc}s</span>
            </div>
          ))}
        </div>
      ) : (
        <p class="text-gray-600 text-sm">No cost data yet</p>
      )}
    </div>

    <!-- ── Top tools ── -->
    <div class="rounded-lg border border-gray-700 bg-[#161b22] p-5">
      <h2 class="text-sm font-semibold text-gray-300 mb-4">Tool Usage</h2>
      {agg.toolUsage.length > 0 ? (
        <div class="space-y-2">
          {agg.toolUsage.map(([tool, count]) => (
            <div class="flex items-center gap-2">
              <span class="text-xs text-gray-400 w-28 truncate flex-shrink-0 font-mono">{tool}</span>
              <div class="flex-1 h-4 rounded bg-gray-800 overflow-hidden">
                <div
                  class="h-full rounded bg-blue-700 hover:bg-blue-500 transition-colors"
                  style={`width: ${(count / maxTool) * 100}%`}
                />
              </div>
              <span class="text-xs text-blue-400 font-mono w-16 text-right">{count.toLocaleString()}</span>
            </div>
          ))}
        </div>
      ) : (
        <p class="text-gray-600 text-sm">No tool data yet</p>
      )}
    </div>
  </div>

  <!-- ── Activity heatmap ── -->
  <div class="mt-8 rounded-lg border border-gray-700 bg-[#161b22] p-5">
    <h2 class="text-sm font-semibold text-gray-300 mb-3">Session Activity</h2>
    <div class="overflow-x-auto">
      <!-- Month labels -->
      <div class="relative mb-1" style="width: max-content; padding-left: 24px;">
        <div style={`display: grid; grid-template-columns: repeat(${WEEKS}, 12px); gap: 3px; min-width: max-content;`}>
          {Array.from({ length: WEEKS }, (_, col) => {
            const m = heatmapMonths.find(m => m.col === col);
            return <div class="text-[9px] text-gray-600 whitespace-nowrap overflow-visible">{m?.label ?? ''}</div>;
          })}
        </div>
      </div>

      <!-- Grid: rows = days of week, cols = weeks -->
      <div class="flex gap-1">
        <!-- Day labels -->
        <div class="flex flex-col gap-0.5 mr-1">
          {['M','','W','','F','',''].map((d, i) => (
            <div class="text-[9px] text-gray-600 h-3 leading-3 w-3 text-right">{d}</div>
          ))}
        </div>

        <div style={`display: grid; grid-template-rows: repeat(7, 12px); grid-template-columns: repeat(${WEEKS}, 12px); grid-auto-flow: column; gap: 3px;`}>
          {heatmapCells.map(({ date, count, future }) => (
            <div
              title={`${date}: ${count} session${count !== 1 ? 's' : ''}`}
              style={`background: ${future ? 'transparent' : heatColor(count)}; border-radius: 2px; width: 12px; height: 12px;`}
            />
          ))}
        </div>
      </div>

      <!-- Legend -->
      <div class="flex items-center gap-1 mt-2 text-[10px] text-gray-600">
        <span>Less</span>
        {[0,1,2,3,5].map(n => (
          <div style={`background: ${heatColor(n)}; width: 12px; height: 12px; border-radius: 2px;`} />
        ))}
        <span>More</span>
      </div>
    </div>
  </div>
</Layout>
