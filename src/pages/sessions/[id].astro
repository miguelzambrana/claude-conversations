---
import Layout from '../../layouts/Layout.astro';
import ConversationView from '../../components/ConversationView.tsx';
import GitCommitPanel from '../../components/GitCommitPanel.tsx';
import FilesTouchedPanel from '../../components/FilesTouchedPanel.astro';
import SessionSummary from '../../components/SessionSummary.astro';
import { findSessionFile, deriveProjectName } from '../../lib/projects.ts';
import { parseSession, getSessionMetadata, extractFilesTouched } from '../../lib/parser.ts';
import { computeMessagesCost } from '../../lib/analytics.ts';
import { getGitBranch } from '../../lib/git.ts';
import { basename } from 'node:path';

const { id } = Astro.params;
if (!id) return Astro.redirect('/');

const filePath = findSessionFile(id);
if (!filePath) return new Response('Session not found', { status: 404 });

const [messages, meta] = await Promise.all([
  parseSession(filePath),
  getSessionMetadata(filePath),
]);

const branch     = meta.cwd ? getGitBranch(meta.cwd) : null;
const slug       = meta.slug || id.slice(0, 8);
const files      = extractFilesTouched(messages);
const totalCost  = computeMessagesCost(messages);

// Session summary stats
const bashCount      = messages.reduce((n, m) => n + m.content.filter(b => b.type === 'tool_use' && (b as any).name === 'Bash').length, 0);
const hasSidechains  = messages.some(m => m.isSidechain);
const projectName    = deriveProjectName(meta.cwd, basename(filePath, '.jsonl'));

// Dominant model (most used in this session)
const modelCounts: Record<string, number> = {};
for (const msg of messages) {
  if (msg.role === 'assistant' && msg.model) {
    const m = msg.model.toLowerCase();
    const key = m.includes('opus') ? 'opus' : m.includes('sonnet') ? 'sonnet' : m.includes('haiku') ? 'haiku' : null;
    if (key) modelCounts[key] = (modelCounts[key] ?? 0) + 1;
  }
}
const dominantModel = Object.entries(modelCounts).sort((a, b) => b[1] - a[1])[0]?.[0] ?? null;
---

<Layout title={`${slug} — Claude Conversations`} back={{ href: 'javascript:history.back()', label: 'Back' }}>
  <div class="flex gap-6">
    <!-- Conversation -->
    <div class="flex-1 min-w-0">
      <div class="mb-4">
        <h1 class="text-xl font-bold text-gray-100 truncate">{slug}</h1>
        <div class="flex flex-wrap gap-3 mt-1 text-xs text-gray-500">
          <span>{new Date(meta.timestamp).toLocaleString()}</span>
          {meta.gitBranch && <span class="font-mono">branch: {meta.gitBranch}</span>}
          <span>{meta.messageCount} messages</span>
          <span class="truncate max-w-xs">{meta.cwd}</span>
        </div>
      </div>

      <SessionSummary
        projectName={projectName}
        totalCost={totalCost}
        bashCount={bashCount}
        files={files}
        hasSidechains={hasSidechains}
        dominantModel={dominantModel}
      />

      <ConversationView messages={messages} sessionId={id} client:load />
    </div>

    <!-- Git sidebar -->
    <aside class="hidden lg:block w-80 flex-shrink-0 space-y-4">
      <!-- Session info -->
      <div class="rounded-md border border-gray-700 bg-[#161b22] p-4">
        <h3 class="text-xs font-semibold uppercase tracking-wider text-gray-500 mb-2">Session</h3>
        <p class="text-xs text-gray-400 font-mono break-all">{id}</p>
        <div class="flex gap-3 mt-2 text-xs text-gray-500">
          <span>{messages.length} messages</span>
          {totalCost > 0.0001 && <span class="text-emerald-600 font-mono font-semibold">${totalCost.toFixed(3)}</span>}
        </div>
      </div>

      <FilesTouchedPanel files={files} />

      <GitCommitPanel cwd={meta.cwd} branch={branch} client:load />
    </aside>
  </div>
</Layout>
